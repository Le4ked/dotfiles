# Theme
theme = Catppuccin Mocha

# Font
font-family = "JetBrainsMono Nerd Font"
font-size = 11

# Cursor
cursor-style = block
cursor-style-blink = true

# Window
background-opacity = 0.60
background-blur =  30
window-decoration = auto
confirm-close-surface = false

# Integration
shell-integration = zsh

# keybinds
